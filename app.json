{
  "expo": {
    "name": "GradePlanner",
    "slug": "gradeplanner",
    "version": "0.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F7F2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.blazeraven.gradeplanner",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F7F2"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "O GradePlanner usa a galeria para foto de perfil e anexos locais."
        }
      ],
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6B4EFF",
          "sounds": []
        }
      ],
      "expo-localization",
      "expo-sqlite"
    ],
    "extra": {
      "useMockApi": true,
      "apiBaseUrl": "http://localhost:3333",
      "eas": {
        "projectId": "1d1d2db7-6913-413a-bdb8-bf1add721279"
      }
    }
  }
}
